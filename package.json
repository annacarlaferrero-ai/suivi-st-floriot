<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Suivi ST — Floriot</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f5f6f8;--bg2:#fff;--bg3:#f0f2f5;--border:#e4e6ea;--border2:#ccc;
  --text:#1a1a2e;--text2:#555;--text3:#999;
  --accent:#1B4F8A;--accent-lt:#e8f0fa;--accent2:#2563b0;
  --danger:#dc2626;--ok:#16a34a;--warn:#d97706;
  --font:'Inter',sans-serif;--mono:'IBM Plex Mono',monospace;--r:6px;
  --shadow:0 1px 4px rgba(0,0,0,.08);
}
html,body{height:100%;font-family:var(--font);background:var(--bg);color:var(--text);font-size:13px;line-height:1.5;overflow:hidden}
button{cursor:pointer;font-family:var(--font)}
.shell{display:grid;grid-template-rows:56px 1fr;height:100vh}
.topbar{background:#fff;border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:14px;box-shadow:var(--shadow);z-index:10;flex-shrink:0}
.logo-img{height:36px;object-fit:contain}
.topbar-div{width:1px;height:24px;background:var(--border2)}
.bc{font-size:12px;color:var(--text2);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.bc-a{color:var(--accent);font-weight:600}
.btn{font-size:12px;font-weight:500;padding:6px 14px;border:1px solid var(--border2);background:#fff;color:var(--text2);border-radius:var(--r);transition:all .12s;white-space:nowrap}
.btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-lt)}
.btn:disabled{opacity:.4;cursor:not-allowed}
.btn-p{border-color:var(--accent);color:#fff;background:var(--accent)}
.btn-p:hover{background:var(--accent2);border-color:var(--accent2);color:#fff}
.btn-d{border-color:#fca5a5;color:var(--danger)}
.btn-d:hover{background:#fef2f2;border-color:var(--danger)}
.main{display:grid;grid-template-columns:240px 1fr;overflow:hidden;min-height:0}
.sidebar{background:#fff;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;box-shadow:var(--shadow)}
.sb-head{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.sb-head-lbl{font-size:11px;font-weight:600;color:var(--text3);letter-spacing:.06em;text-transform:uppercase}
.sb-list{flex:1;overflow-y:auto;padding:8px}
.sb-list::-webkit-scrollbar{width:3px}
.sb-list::-webkit-scrollbar-thumb{background:var(--border2)}
.sb-item{padding:10px 12px;border-radius:var(--r);border:1px solid transparent;margin-bottom:3px;transition:all .1s;cursor:pointer}
.sb-item:hover{background:var(--bg3)}
.sb-item.active{background:var(--accent-lt);border-color:var(--accent)}
.si-name{font-size:12px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.si-sub{font-size:11px;color:var(--text3);margin-top:2px;font-family:var(--mono)}
.si-dgd{font-size:10px;font-weight:500;margin-top:3px}
.dgd-ok{color:var(--ok)}.dgd-no{color:var(--text3)}
.sb-foot{padding:12px 16px;border-top:1px solid var(--border);flex-shrink:0;display:flex;flex-direction:column;gap:7px}
.sb-foot .btn{width:100%;text-align:center}
.sb-empty{padding:32px 14px;color:var(--text3);font-size:12px;text-align:center;line-height:1.9}
.content{overflow-y:auto;min-height:0;background:var(--bg)}
.content::-webkit-scrollbar{width:4px}
.content::-webkit-scrollbar-thumb{background:var(--border2)}
.vue{padding:24px;display:none}
.vue.active{display:block}
.page-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.page-title{font-size:16px;font-weight:600}
.page-sub{font-size:12px;color:var(--text3);margin-bottom:20px}
.ch-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:14px}
.cc{background:#fff;border:1px solid var(--border);border-radius:8px;padding:18px;transition:all .12s;cursor:pointer;box-shadow:var(--shadow)}
.cc:hover{border-color:var(--accent);box-shadow:0 4px 12px rgba(27,79,138,.1)}
.cc.cur{border-color:var(--accent);border-left:3px solid var(--accent)}
.cc-num{font-family:var(--mono);font-size:10px;color:var(--text3);margin-bottom:3px}
.cc-nom{font-size:14px;font-weight:600;margin-bottom:10px}
.cc-row{display:flex;gap:12px;font-size:11px;color:var(--text3);margin-bottom:3px}
.cc-row span{color:var(--text2);font-weight:500}
.cc-acts{margin-top:14px;padding-top:12px;border-top:1px solid var(--border);display:flex;gap:6px}
.fiche-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border);gap:12px;flex-wrap:wrap}
.fiche-name{font-size:18px;font-weight:600}
.fiche-lot{font-size:12px;color:var(--text3);margin-top:3px;font-family:var(--mono)}
.fiche-acts{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px}
.badge-ok{background:#dcfce7;color:var(--ok)}.badge-warn{background:#fef3c7;color:var(--warn)}
.section{background:#fff;border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:16px;box-shadow:var(--shadow)}
.sec-hdr{padding:10px 16px;background:var(--accent);display:flex;align-items:center;justify-content:space-between}
.sec-hdr span{font-size:11px;font-weight:600;color:#fff;letter-spacing:.05em;text-transform:uppercase}
.btn-add{font-size:12px;font-weight:500;color:rgba(255,255,255,.85);background:transparent;border:1px solid rgba(255,255,255,.3);border-radius:4px;padding:3px 10px;transition:all .1s}
.btn-add:hover{background:rgba(255,255,255,.15);color:#fff}
.tscroll{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
th{padding:8px 10px;text-align:left;font-size:11px;font-weight:600;color:var(--text2);background:var(--bg3);border-bottom:1px solid var(--border);white-space:nowrap}
td{padding:5px 8px;border-bottom:1px solid var(--bg3);color:var(--text)}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafbfc}
.tn{text-align:right;font-family:var(--mono);font-size:11px;color:var(--text2);white-space:nowrap}
.tp{color:var(--ok);font-weight:600}.tng{color:var(--danger);font-weight:600}
td input{background:transparent;border:none;color:var(--text);font-family:var(--font);font-size:12px;width:100%;outline:none;padding:2px 0;min-width:50px}
td input:focus{background:var(--accent-lt);border-radius:3px;padding:2px 5px}
td input[type=number]{text-align:right;font-family:var(--mono);font-size:11px;color:var(--text2)}
.td-x{width:22px;text-align:center}
.btn-x{background:transparent;border:none;color:var(--text3);font-size:16px;line-height:1;border-radius:3px;padding:0 3px;transition:color .1s}
.btn-x:hover{color:var(--danger)}
.tr-tot td{font-weight:600;background:var(--accent-lt);font-family:var(--mono);font-size:11px;color:var(--accent)}
.ec-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px}
.ec-card{background:#fff;border:1px solid var(--border);border-radius:8px;padding:12px 16px;box-shadow:var(--shadow)}
.ec-lbl{font-size:10px;font-weight:600;color:var(--text3);letter-spacing:.06em;text-transform:uppercase;margin-bottom:6px}
.ec-val{font-family:var(--mono);font-size:16px;font-weight:600;color:var(--text2)}
.ec-pos .ec-val{color:var(--ok)}.ec-neg .ec-val{color:var(--danger)}
.al-row{display:grid;grid-template-columns:1fr 120px 120px 26px;border-bottom:1px solid var(--bg3);background:#fff}
.al-row:hover{background:#fafbfc}
.al-row input{background:transparent;border:none;color:var(--text);font-family:var(--font);font-size:12px;padding:7px 10px;outline:none;width:100%}
.al-row input:focus{background:var(--accent-lt)}
.al-row input[type=number]{text-align:right;font-family:var(--mono);font-size:11px;color:var(--text2)}
.al-foot{display:grid;grid-template-columns:1fr 120px 120px 26px;padding:8px 10px;background:var(--accent-lt);font-family:var(--mono);font-size:11px;font-weight:600;color:var(--accent);border-top:1px solid var(--border)}
.al-foot span:not(:first-child){text-align:right}
.synth-bar{background:#fff;border:1px solid var(--border);border-radius:8px;padding:12px 18px;display:flex;align-items:center;gap:16px;margin-bottom:16px;box-shadow:var(--shadow);flex-wrap:wrap}
.sl{font-size:11px;color:var(--text3);font-weight:500}
.sv{font-family:var(--mono);font-size:12px;color:var(--accent);font-weight:600;margin-left:4px}
.synth-wrap{overflow-x:auto;background:#fff;border:1px solid var(--border);border-radius:8px;box-shadow:var(--shadow)}
.synth-wrap table{min-width:900px}
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:999;display:none;align-items:center;justify-content:center}
.overlay.open{display:flex}
.modal{background:#fff;border:1px solid var(--border);border-radius:10px;padding:28px;width:440px;max-width:95vw;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.15)}
.modal h3{font-size:15px;font-weight:600;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid var(--border)}
.m-acts{display:flex;gap:8px;justify-content:flex-end;margin-top:22px}
.field{margin-bottom:14px}
.field label{display:block;font-size:11px;font-weight:600;color:var(--text2);margin-bottom:5px}
.field input,.field select{width:100%;background:#fff;border:1px solid var(--border2);color:var(--text);font-family:var(--font);font-size:13px;padding:9px 12px;border-radius:var(--r);outline:none;transition:border .12s}
.field input:focus,.field select:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(27,79,138,.08)}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.toast{position:fixed;bottom:24px;right:24px;background:var(--accent);color:#fff;padding:10px 18px;border-radius:8px;font-size:12px;font-weight:500;z-index:9999;opacity:0;transition:opacity .3s;pointer-events:none}
.toast.show{opacity:1}
.loading{text-align:center;padding:40px;color:var(--text3);font-size:12px}
</style>
</head>
<body>
<div class="shell">

<!-- MODALS -->
<div class="overlay" id="m-ch">
  <div class="modal">
    <h3>Nouveau chantier</h3>
    <div class="field"><label>Numéro</label><input id="mc-num" type="text" placeholder="ex : 2024-042"></div>
    <div class="field"><label>Nom du chantier</label><input id="mc-nom" type="text" placeholder="ex : Résidence Les Acacias"></div>
    <div class="field"><label>Gestion à fin</label><input id="mc-date" type="month"></div>
    <div class="m-acts">
      <button class="btn" onclick="closeM('m-ch')">Annuler</button>
      <button class="btn btn-p" onclick="creerChantier()">Créer</button>
    </div>
  </div>
</div>

<div class="overlay" id="m-st">
  <div class="modal">
    <h3>Créer une fiche ST</h3>
    <div class="field"><label>Nom du sous-traitant</label><input id="st-nom" type="text" placeholder="ex : SARL Maçonnerie Dupont"></div>
    <div class="field"><label>Lot</label>
      <select id="st-lot">
        <option value="">-- Sélectionner --</option>
        <optgroup label="1 – Gros œuvre">
          <option>ST ACIERS</option><option>ST BETON</option><option>ST CARROTAGE SCIAGE</option>
          <option>ST COULAGES PLANCHERS</option><option>ST CUVELAGE</option><option>ST DALLE</option>
          <option>ST ECHAFFAUDAGES</option><option>ST ESPACES VERTS</option>
          <option>ST FONDATIONS SPECIALES</option><option>ST GROS ŒUVRE</option>
          <option>ST INSTALLATIONS DE CHANTIER</option><option>ST MACONNERIE</option>
          <option>ST PRORATA</option><option>ST REPRISES EN SOUS ŒUVRE</option>
          <option>ST STRUCTURE PREFA</option><option>ST VOILES</option>
          <option>ST ETAIEMENT</option><option>ST PLANCHER PREFA</option>
        </optgroup>
        <optgroup label="2 – Terrassements">
          <option>ST RABATTEMENT DE NAPPE</option><option>ST ASSAINISSEMENT</option>
          <option>ST DEMOLITION</option><option>ST DEPOLLUTION</option>
          <option>ST SIGNALISATION</option><option>ST TERRASSEMENTS</option>
          <option>ST BLINDAGE</option><option>ST TRANSPORT MATERIAUX</option><option>ST VRD</option>
        </optgroup>
        <optgroup label="3 – Corps d'état">
          <option>ST BARDAGE</option><option>ST CHARPENTE BOIS</option><option>ST CHARPENTE METAL</option>
          <option>ST COUVERTURE</option><option>ST ETANCHEITE</option><option>ST FACADES</option>
          <option>ST FACADES ITE</option><option>ST ISOLATION EXTERIEURE</option>
          <option>ST MENUISERIE EXT ALU</option><option>ST MENUISERIE EXT BOIS</option>
          <option>ST MENUISERIE EXT PVC</option><option>ST MURS RIDEAUX</option>
          <option>ST OCCULTATION</option><option>ST PORTE DE GARAGE</option><option>ST SERRURERIE</option>
        </optgroup>
        <optgroup label="4 – Second œuvre">
          <option>ST ALEAS</option><option>ST CARRELAGE</option><option>ST CHAPES</option>
          <option>ST CLOISONS AMOVIBLES</option><option>ST CLOISONS DOUBLAGE STAFF</option>
          <option>ST ENTREPRISE GENERALE</option><option>ST FAUX PLAFONDS</option>
          <option>ST FINITIONS</option><option>ST FLOCAGE</option>
          <option>ST ISOLATION INTERIEURE</option><option>ST MENUISERIE INT</option>
          <option>ST NETTOYAGE</option><option>ST PARQUETS</option><option>ST PEINTURE</option>
          <option>ST PLAFONDS SUSPENDUS</option><option>ST PLATERIE</option>
          <option>ST SECOND ŒUVRE</option><option>ST SIGNALETIQUE</option>
          <option>ST SOL SOUPLE</option><option>ST TRAITEMENT DE SURFACE</option>
        </optgroup>
        <optgroup label="5 – CET">
          <option>ST ASCENSEUR</option><option>ST CUISINE</option><option>ST CVC</option>
          <option>ST ELECTRICITE</option><option>ST ELECTRICITE COURANTS FAIBLES</option>
          <option>ST ELECTRICITE COURANTS FORTS</option><option>ST PLOMBERIE</option>
          <option>ST SECURITE INCENDIE SPRINKLAGE</option>
        </optgroup>
      </select>
    </div>
    <div class="field-row">
      <div class="field"><label>Budget P0 (€)</label><input id="st-bp0" type="number" placeholder="0"></div>
      <div class="field"><label>Marché initial (€)</label><input id="st-mar" type="number" placeholder="0"></div>
    </div>
    <div class="field"><label>DGD signé ?</label>
      <select id="st-dgd"><option value="NON">NON</option><option value="OUI">OUI</option></select>
    </div>
    <div class="m-acts">
      <button class="btn" onclick="closeM('m-st')">Annuler</button>
      <button class="btn btn-p" onclick="creerST()">Créer la fiche</button>
    </div>
  </div>
</div>

<div class="overlay" id="m-gest">
  <div class="modal">
    <h3>Initier une nouvelle gestion</h3>
    <p style="color:var(--text2);font-size:12px;line-height:1.7;margin-bottom:16px">Les valeurs <strong>Total FDC</strong> actuelles seront copiées dans <strong>FDC M-1</strong> sur toutes les fiches ST de ce chantier.</p>
    <div class="field"><label>Nouvelle date de gestion</label><input id="ng-date" type="month"></div>
    <div class="m-acts">
      <button class="btn" onclick="closeM('m-gest')">Annuler</button>
      <button class="btn btn-p" onclick="initierGestion()">Confirmer</button>
    </div>
  </div>
</div>

<!-- TOPBAR -->
<div class="topbar">
  <img class="logo-img" src="data:image/png;base64," alt="Floriot">
  <div class="topbar-div"></div>
  <div class="bc" id="bc">Mes chantiers</div>
  <button class="btn" onclick="goChantiers()">⊞ Chantiers</button>
  <button class="btn btn-p" id="btn-export" style="display:none" onclick="exportXlsx()">↓ Export xlsx</button>
  <button class="btn btn-p" onclick="openM('m-ch')">+ Nouveau chantier</button>
</div>

<div class="main">
  <div class="sidebar">
    <div class="sb-head">
      <span class="sb-head-lbl" id="sb-lbl">Chantiers</span>
      <button class="btn btn-p" id="btn-add-st" style="display:none;padding:4px 10px;font-size:11px" onclick="openM('m-st')">+ ST</button>
    </div>
    <div class="sb-list" id="sb-list"><div class="sb-empty">Chargement…</div></div>
    <div class="sb-foot" id="sb-foot" style="display:none">
      <button class="btn" onclick="openM('m-gest')">⟳ Nouvelle gestion</button>
      <button class="btn" onclick="showSynthese()">≡ Synthèse chantier</button>
    </div>
  </div>

  <div class="content">
    <div class="vue active" id="vue-ch">
      <div class="page-hdr"><div class="page-title">Mes chantiers</div><button class="btn btn-p" onclick="openM('m-ch')">+ Nouveau</button></div>
      <div class="page-sub" id="ch-sub">Chargement…</div>
      <div class="ch-grid" id="ch-grid"></div>
    </div>

    <div class="vue" id="vue-fiche">
      <div class="fiche-hdr">
        <div><div class="fiche-name" id="f-name">—</div><div class="fiche-lot" id="f-lot">—</div></div>
        <div class="fiche-acts">
          <span class="badge badge-warn" id="f-dgd">DGD NON</span>
          <button class="btn" onclick="toggleDGD()">Basculer DGD</button>
          <button class="btn btn-d" onclick="supprimerST()">Supprimer</button>
        </div>
      </div>
      <div class="section">
        <div class="sec-hdr"><span>Budget</span><button class="btn-add" onclick="addBudget()">+ ligne</button></div>
        <div class="tscroll"><table>
          <thead><tr><th>Désignation</th><th style="text-align:right;min-width:110px">Budget P0 (€)</th><th style="text-align:right;min-width:110px">Travaux sup (€)</th><th style="text-align:right;min-width:110px">Transfert (€)</th><th style="text-align:right;min-width:115px">Budget recalé (€)</th><th style="width:22px"></th></tr></thead>
          <tbody id="tb-b"></tbody>
          <tfoot><tr class="tr-tot"><td>TOTAL</td><td class="tn" id="t-bp0">0</td><td class="tn" id="t-sup">0</td><td class="tn" id="t-trf">0</td><td class="tn" id="t-brec">0</td><td></td></tr></tfoot>
        </table></div>
      </div>
      <div class="section">
        <div class="sec-hdr"><span>Dépenses</span><button class="btn-add" onclick="addDep()">+ ligne</button></div>
        <div class="tscroll"><table>
          <thead><tr><th style="min-width:55px">Qui</th><th style="min-width:130px">Désignation</th><th style="text-align:right;min-width:100px">Montant PM (€)</th><th style="text-align:right;min-width:100px">Marché (€)</th><th style="text-align:right;min-width:100px">Avenant (€)</th><th style="text-align:right;min-width:36px">n°AV</th><th style="text-align:right;min-width:110px">Total marché (€)</th><th style="text-align:right;min-width:110px">RAD / Provision (€)</th><th style="text-align:right;min-width:100px">Total FDC (€)</th><th style="width:22px"></th></tr></thead>
          <tbody id="tb-d"></tbody>
          <tfoot><tr class="tr-tot"><td colspan="2">TOTAL</td><td class="tn" id="t-pm">0</td><td class="tn" id="t-mar">0</td><td class="tn" id="t-av">0</td><td></td><td class="tn" id="t-tmar">0</td><td class="tn" id="t-rad">0</td><td class="tn" id="t-fdc">0</td><td></td></tr></tfoot>
        </table></div>
      </div>
      <div class="ec-grid">
        <div class="ec-card"><div class="ec-lbl">Budget recalé</div><div class="ec-val" id="ec-br">0 €</div></div>
        <div class="ec-card"><div class="ec-lbl">Dépenses FDC</div><div class="ec-val" id="ec-fdc">0 €</div></div>
        <div class="ec-card" id="ec-c1"><div class="ec-lbl">Écart</div><div class="ec-val" id="ec-e">0 €</div></div>
      </div>
      <div class="ec-grid">
        <div class="ec-card"><div class="ec-lbl">FDC M-1</div><div class="ec-val" id="ec-m1">0 €</div></div>
        <div class="ec-card"><div class="ec-lbl">Dépenses FDC</div><div class="ec-val" id="ec-fdc2">0 €</div></div>
        <div class="ec-card" id="ec-c2"><div class="ec-lbl">Écart M-1</div><div class="ec-val" id="ec-em1">0 €</div></div>
      </div>
      <div class="section">
        <div class="sec-hdr"><span>Risques &amp; opportunités</span><button class="btn-add" onclick="addAleas()">+ ligne</button></div>
        <div id="al-body"></div>
        <div class="al-foot"><span>TOTAL</span><span id="t-ris">0 €</span><span id="t-opp">0 €</span><span></span></div>
      </div>
    </div>

    <div class="vue" id="vue-synth">
      <div class="page-hdr" style="margin-bottom:14px">
        <div class="page-title" id="s-title">Synthèse</div>
        <button class="btn" onclick="retourFiche()">← Retour</button>
      </div>
      <div class="synth-bar">
        <span class="sl">Gestion :</span><span class="sv" id="s-date">—</span>
        <span class="sl" style="margin-left:8px">Fiches ST :</span><span class="sv" id="s-nb">0</span>
        <span style="flex:1"></span>
        <span class="sl">Budget recalé :</span><span class="sv" id="s-br">—</span>
        <span class="sl" style="margin-left:10px">Total FDC :</span><span class="sv" id="s-fdc">—</span>
        <span class="sl" style="margin-left:10px">Écart :</span><span class="sv" id="s-ec">—</span>
      </div>
      <div class="synth-wrap"><table>
        <thead><tr><th>Lot</th><th>Entreprise</th><th>DGD</th><th style="text-align:right">Budget P0</th><th style="text-align:right">Budget recalé</th><th style="text-align:right">Total marché</th><th style="text-align:right">RAD</th><th style="text-align:right">Total FDC</th><th style="text-align:right">Écart</th><th style="text-align:right">FDC M-1</th><th style="text-align:right">Écart M-1</th></tr></thead>
        <tbody id="tb-s"></tbody>
      </table></div>
    </div>
  </div>
</div>
</div>
<div class="toast" id="toast"></div>

<script>
let chantiers=[], chId=null, stId=null, currentFiches=[];

function n(v){return parseFloat(v)||0;}
function fmt(v){return n(v).toLocaleString('fr-FR',{minimumFractionDigits:0,maximumFractionDigits:0});}
function fmtS(v){v=n(v);return(v>=0?'+':'')+fmt(v)+' €';}
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2,6);}
function openM(id){document.getElementById(id).classList.add('open');}
function closeM(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open');}));
function showVue(id){document.querySelectorAll('.vue').forEach(v=>v.classList.remove('active'));document.getElementById(id).classList.add('active');}
function bc(parts){document.getElementById('bc').innerHTML=parts.map((p,i)=>i===parts.length-1?'<span class="bc-a">'+p+'</span>':p).join(' › ');}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2500);}

async function api(method, path, body){
  const opts={method,headers:{'Content-Type':'application/json'}};
  if(body)opts.body=JSON.stringify(body);
  const r=await fetch('/api'+path,opts);
  return r.json();
}

// ── CHANTIERS ──────────────────────────────────────────────
async function loadChantiers(){
  chantiers=await api('GET','/chantiers');
  renderSB(); renderCh();
}

async function creerChantier(){
  const num=document.getElementById('mc-num').value.trim();
  const nom=document.getElementById('mc-nom').value.trim();
  const date=document.getElementById('mc-date').value;
  if(!nom){alert('Saisissez un nom.');return;}
  const id=uid();
  await api('POST','/chantiers',{id,num,nom,date,gestion_date:date});
  document.getElementById('mc-num').value='';document.getElementById('mc-nom').value='';
  closeM('m-ch'); await loadChantiers(); ouvrirChantier(id);
}

async function ouvrirChantier(id){
  chId=id; stId=null;
  const c=chantiers.find(x=>x.id===id);
  document.getElementById('sb-lbl').textContent='Fiches ST';
  document.getElementById('btn-add-st').style.display='';
  document.getElementById('sb-foot').style.display='';
  document.getElementById('btn-export').style.display='';
  bc([c.num?c.num+' – '+c.nom:c.nom]);
  currentFiches=await api('GET','/chantiers/'+id+'/fiches');
  renderSB();
  if(currentFiches.length)ouvrirST(currentFiches[0].id);
  else{renderCh();showVue('vue-ch');}
}

function goChantiers(){
  chId=null;stId=null;currentFiches=[];
  document.getElementById('sb-lbl').textContent='Chantiers';
  document.getElementById('btn-add-st').style.display='none';
  document.getElementById('sb-foot').style.display='none';
  document.getElementById('btn-export').style.display='none';
  bc(['Mes chantiers']);renderSB();renderCh();showVue('vue-ch');
}

function renderCh(){
  const grid=document.getElementById('ch-grid');
  const sub=document.getElementById('ch-sub');
  if(!chantiers.length){sub.textContent='Aucun chantier.';grid.innerHTML='';return;}
  sub.textContent=chantiers.length+' chantier(s).';
  grid.innerHTML=chantiers.map(c=>{
    return '<div class="cc '+(c.id===chId?'cur':'')+'" onclick="ouvrirChantier(\''+c.id+'\')">'+
      '<div class="cc-num">'+(c.num||'—')+'</div>'+
      '<div class="cc-nom">'+c.nom+'</div>'+
      '<div class="cc-row"><span>'+(c.date||'—')+'</span></div>'+
      '<div class="cc-acts"><button class="btn btn-d" onclick="event.stopPropagation();suppCh(\''+c.id+'\')">Supprimer</button></div>'+
      '</div>';
  }).join('');
}

async function suppCh(id){
  const c=chantiers.find(x=>x.id===id);
  if(!confirm('Supprimer "'+c.nom+'" ?'))return;
  await api('DELETE','/chantiers/'+id);
  await loadChantiers(); goChantiers();
}

function renderSB(){
  const el=document.getElementById('sb-list');
  if(!chId){
    if(!chantiers.length){el.innerHTML='<div class="sb-empty">Aucun chantier.</div>';return;}
    el.innerHTML=chantiers.map(c=>'<div class="sb-item '+(c.id===chId?'active':'')+'" onclick="ouvrirChantier(\''+c.id+'\')">'+
      '<div class="si-name">'+c.nom+'</div>'+
      '<div class="si-sub">'+(c.num||'—')+'</div></div>').join('');return;
  }
  if(!currentFiches.length){el.innerHTML='<div class="sb-empty">Aucune fiche ST.</div>';return;}
  el.innerHTML=currentFiches.map(f=>'<div class="sb-item '+(f.id===stId?'active':'')+'" onclick="ouvrirST(\''+f.id+'\')">'+
    '<div class="si-name">'+f.nom+'</div>'+
    '<div class="si-sub">'+f.lot+'</div>'+
    '<div class="si-dgd '+(f.dgd==='OUI'?'dgd-ok':'dgd-no')+'">DGD '+f.dgd+'</div></div>').join('');
}

// ── FICHES ST ──────────────────────────────────────────────
async function creerST(){
  const nom=document.getElementById('st-nom').value.trim();
  const lot=document.getElementById('st-lot').value;
  const bp0=n(document.getElementById('st-bp0').value);
  const mar=n(document.getElementById('st-mar').value);
  const dgd=document.getElementById('st-dgd').value;
  if(!nom||!lot){alert('Nom et lot obligatoires.');return;}
  const id=uid();
  await api('POST','/fiches',{id,chantier_id:chId,nom,lot,dgd,
    budget:[{desig:'Marché initial',bp0,sup:0,transf:0}],
    depenses:[{qui:'',desig:'',pm:0,marche:mar,av:0,nav:'',rad:0}]});
  document.getElementById('st-nom').value='';document.getElementById('st-bp0').value='';
  document.getElementById('st-mar').value='';document.getElementById('st-dgd').value='NON';
  closeM('m-st');
  currentFiches=await api('GET','/chantiers/'+chId+'/fiches');
  stId=id; renderSB(); openST(currentFiches.find(f=>f.id===id));
  toast('Fiche ST créée !');
}

function ouvrirST(id){
  stId=id; renderSB();
  openST(currentFiches.find(f=>f.id===id));
}

function st(){return currentFiches.find(f=>f.id===stId);}
function ch(){return chantiers.find(c=>c.id===chId);}

function openST(f){
  const c=ch();
  bc([c.num?c.num+' – '+c.nom:c.nom,f.nom]);
  showVue('vue-fiche');
  document.getElementById('f-name').textContent=f.nom;
  document.getElementById('f-lot').textContent=f.lot+(c.gestion_date?' · gestion '+c.gestion_date:'');
  const b=document.getElementById('f-dgd');
  b.textContent='DGD '+f.dgd;b.className='badge '+(f.dgd==='OUI'?'badge-ok':'badge-warn');
  renderB(f);renderD(f);renderEC(f);renderAL(f);
}

async function toggleDGD(){
  const f=st();
  const newDgd=f.dgd==='OUI'?'NON':'OUI';
  await api('PATCH','/fiches/'+f.id+'/dgd',{dgd:newDgd});
  f.dgd=newDgd; renderSB(); openST(f);
}

async function supprimerST(){
  const f=st();
  if(!confirm('Supprimer "'+f.nom+'" ?'))return;
  await api('DELETE','/fiches/'+f.id);
  currentFiches=currentFiches.filter(x=>x.id!==stId);
  stId=currentFiches.length?currentFiches[0].id:null;
  renderSB();
  if(stId)ouvrirST(stId);else{renderCh();showVue('vue-ch');}
}

// ── CALCULS ────────────────────────────────────────────────
function getBR(f){return(f.budget||[]).reduce((s,r)=>s+n(r.bp0)+n(r.sup)+n(r.transf),0);}
function getFDC(f){return(f.depenses||[]).reduce((s,r)=>s+n(r.marche)+n(r.av)+n(r.rad),0);}

// ── BUDGET ─────────────────────────────────────────────────
function renderB(f){
  document.getElementById('tb-b').innerHTML=(f.budget||[]).map((r)=>
    '<tr><td><input value="'+(r.desig||'')+'" onblur="upB(\''+r.id+'\',this)"></td>'+
    '<td><input type="number" value="'+(r.bp0||'')+'" onblur="upB(\''+r.id+'\',this)"></td>'+
    '<td><input type="number" value="'+(r.sup||'')+'" onblur="upB(\''+r.id+'\',this)"></td>'+
    '<td><input type="number" value="'+(r.transf||'')+'" onblur="upB(\''+r.id+'\',this)"></td>'+
    '<td class="tn">'+fmt(n(r.bp0)+n(r.sup)+n(r.transf))+'</td>'+
    '<td class="td-x"><button class="btn-x" onclick="delB(\''+r.id+'\')">×</button></td></tr>').join('');
  let bp0=0,sup=0,trf=0,rec=0;
  (f.budget||[]).forEach(r=>{bp0+=n(r.bp0);sup+=n(r.sup);trf+=n(r.transf);rec+=n(r.bp0)+n(r.sup)+n(r.transf);});
  document.getElementById('t-bp0').textContent=fmt(bp0);
  document.getElementById('t-sup').textContent=fmt(sup);
  document.getElementById('t-trf').textContent=fmt(trf);
  document.getElementById('t-brec').textContent=fmt(rec);
}

async function upB(id, el){
  const f=st(); const row=f.budget.find(r=>r.id===id);
  const tr=el.closest('tr');
  const inputs=tr.querySelectorAll('input');
  row.desig=inputs[0].value; row.bp0=n(inputs[1].value);
  row.sup=n(inputs[2].value); row.transf=n(inputs[3].value);
  await api('PATCH','/budget/'+id,row);
  renderB(f);renderEC(f);
}

async function addBudget(){
  const f=st();
  const r=await api('POST','/fiches/'+f.id+'/budget',{desig:'',bp0:0,sup:0,transf:0});
  currentFiches=await api('GET','/chantiers/'+chId+'/fiches');
  openST(currentFiches.find(x=>x.id===stId));
}

async function delB(id){
  const f=st();f.budget=f.budget.filter(r=>r.id!==id);
  await api('DELETE','/budget/'+id);
  renderB(f);renderEC(f);
}

// ── DÉPENSES ───────────────────────────────────────────────
function renderD(f){
  document.getElementById('tb-d').innerHTML=(f.depenses||[]).map((r)=>
    '<tr>'+
    '<td><input value="'+(r.qui||'')+'" style="min-width:48px" onblur="upD(\''+r.id+'\',this)"></td>'+
    '<td><input value="'+(r.desig||'')+'" onblur="upD(\''+r.id+'\',this)"></td>'+
    '<td><input type="number" value="'+(r.pm||'')+'" onblur="upD(\''+r.id+'\',this)"></td>'+
    '<td><input type="number" value="'+(r.marche||'')+'" onblur="upD(\''+r.id+'\',this)"></td>'+
    '<td><input type="number" value="'+(r.av||'')+'" onblur="upD(\''+r.id+'\',this)"></td>'+
    '<td><input value="'+(r.nav||'')+'" style="min-width:32px;text-align:right" onblur="upD(\''+r.id+'\',this)"></td>'+
    '<td class="tn">'+fmt(n(r.marche)+n(r.av))+'</td>'+
    '<td><input type="number" value="'+(r.rad||'')+'" onblur="upD(\''+r.id+'\',this)"></td>'+
    '<td class="tn">'+fmt(n(r.marche)+n(r.av)+n(r.rad))+'</td>'+
    '<td class="td-x"><button class="btn-x" onclick="delD(\''+r.id+'\')">×</button></td></tr>').join('');
  let pm=0,m=0,av=0,tm=0,rad=0,fdc=0;
  (f.depenses||[]).forEach(r=>{pm+=n(r.pm);m+=n(r.marche);av+=n(r.av);tm+=n(r.marche)+n(r.av);rad+=n(r.rad);fdc+=n(r.marche)+n(r.av)+n(r.rad);});
  ['pm','mar','av','tmar','rad','fdc'].forEach((id,i)=>document.getElementById('t-'+id).textContent=fmt([pm,m,av,tm,rad,fdc][i]));
}

async function upD(id, el){
  const f=st(); const row=f.depenses.find(r=>r.id===id);
  const tr=el.closest('tr'); const inputs=tr.querySelectorAll('input');
  row.qui=inputs[0].value; row.desig=inputs[1].value; row.pm=n(inputs[2].value);
  row.marche=n(inputs[3].value); row.av=n(inputs[4].value);
  row.nav=inputs[5].value; row.rad=n(inputs[7].value);
  await api('PATCH','/dep/'+id,row);
  renderD(f);renderEC(f);
}

async function addDep(){
  await api('POST','/fiches/'+stId+'/dep',{qui:'',desig:'',pm:0,marche:0,av:0,nav:'',rad:0});
  currentFiches=await api('GET','/chantiers/'+chId+'/fiches');
  openST(currentFiches.find(x=>x.id===stId));
}

async function delD(id){
  const f=st();f.depenses=f.depenses.filter(r=>r.id!==id);
  await api('DELETE','/dep/'+id);
  renderD(f);renderEC(f);
}

// ── ÉCART ──────────────────────────────────────────────────
function renderEC(f){
  const br=getBR(f),fdc=getFDC(f),ec=br-fdc,em1=fdc-n(f.fdc_m1);
  document.getElementById('ec-br').textContent=fmt(br)+' €';
  document.getElementById('ec-fdc').textContent=fmt(fdc)+' €';
  document.getElementById('ec-fdc2').textContent=fmt(fdc)+' €';
  document.getElementById('ec-m1').textContent=fmt(n(f.fdc_m1))+' €';
  document.getElementById('ec-e').textContent=fmtS(ec);
  document.getElementById('ec-em1').textContent=fmtS(em1);
  document.getElementById('ec-c1').className='ec-card '+(ec>0?'ec-pos':ec<0?'ec-neg':'');
  document.getElementById('ec-c2').className='ec-card '+(em1>0?'ec-pos':em1<0?'ec-neg':'');
}

// ── ALÉAS ──────────────────────────────────────────────────
function renderAL(f){
  document.getElementById('al-body').innerHTML=(f.aleas||[]).map((r)=>
    '<div class="al-row">'+
    '<input value="'+(r.desig||'')+'" placeholder="Désignation" onblur="upA(\''+r.id+'\',this)">'+
    '<input type="number" value="'+(r.risque||'')+'" placeholder="Risques €" onblur="upA(\''+r.id+'\',this)">'+
    '<input type="number" value="'+(r.opport||'')+'" placeholder="Opportunités €" onblur="upA(\''+r.id+'\',this)">'+
    '<button class="btn-x" style="margin:auto 3px" onclick="delA(\''+r.id+'\')">×</button></div>').join('');
  let r=0,o=0;(f.aleas||[]).forEach(a=>{r+=n(a.risque);o+=n(a.opport);});
  document.getElementById('t-ris').textContent=fmt(r)+' €';
  document.getElementById('t-opp').textContent=fmt(o)+' €';
}

async function upA(id,el){
  const f=st(); const row=f.aleas.find(r=>r.id===id);
  const div=el.closest('.al-row'); const inputs=div.querySelectorAll('input');
  row.desig=inputs[0].value; row.risque=n(inputs[1].value); row.opport=n(inputs[2].value);
  await api('PATCH','/aleas/'+id,row);
  renderAL(f);
}

async function addAleas(){
  await api('POST','/fiches/'+stId+'/aleas',{desig:'',risque:0,opport:0});
  currentFiches=await api('GET','/chantiers/'+chId+'/fiches');
  openST(currentFiches.find(x=>x.id===stId));
}

async function delA(id){
  const f=st();f.aleas=f.aleas.filter(r=>r.id!==id);
  await api('DELETE','/aleas/'+id);
  renderAL(f);
}

// ── GESTION ────────────────────────────────────────────────
async function initierGestion(){
  const d=document.getElementById('ng-date').value;
  for(const f of currentFiches){
    await api('PATCH','/fiches/'+f.id+'/fdcm1',{fdc_m1:getFDC(f)});
    f.fdc_m1=getFDC(f);
  }
  if(d){await api('PATCH','/chantiers/'+chId+'/gestion',{gestion_date:d});}
  closeM('m-gest');
  chantiers=await api('GET','/chantiers');
  if(stId)openST(st());
  toast(currentFiches.length+' fiche(s) mise(s) à jour.');
}

// ── SYNTHÈSE ───────────────────────────────────────────────
function showSynthese(){
  const c=ch();
  document.getElementById('s-title').textContent='Synthèse — '+c.nom;
  document.getElementById('s-date').textContent=c.gestion_date||c.date||'—';
  document.getElementById('s-nb').textContent=currentFiches.length;
  let tb=0,tf=0;
  const rows=currentFiches.map(f=>{
    const br=getBR(f),fdc=getFDC(f);
    const bp0=(f.budget||[]).reduce((s,r)=>s+n(r.bp0),0);
    const tm=(f.depenses||[]).reduce((s,r)=>s+n(r.marche)+n(r.av),0);
    const rad=(f.depenses||[]).reduce((s,r)=>s+n(r.rad),0);
    const ec=br-fdc,em1=fdc-n(f.fdc_m1);tb+=br;tf+=fdc;
    return '<tr><td style="font-family:var(--mono);font-size:10px;color:var(--text3)">'+f.lot+'</td>'+
      '<td style="font-weight:600;cursor:pointer;color:var(--accent)" onclick="ouvrirST(\''+f.id+'\')">'+f.nom+'</td>'+
      '<td><span class="badge '+(f.dgd==='OUI'?'badge-ok':'badge-warn')+'">'+f.dgd+'</span></td>'+
      '<td class="tn">'+fmt(bp0)+'</td><td class="tn">'+fmt(br)+'</td>'+
      '<td class="tn">'+fmt(tm)+'</td><td class="tn">'+fmt(rad)+'</td>'+
      '<td class="tn">'+fmt(fdc)+'</td>'+
      '<td class="tn '+(ec>=0?'tp':'tng')+'">'+fmtS(ec)+'</td>'+
      '<td class="tn">'+fmt(n(f.fdc_m1))+'</td>'+
      '<td class="tn '+(em1>=0?'tp':'tng')+'">'+fmtS(em1)+'</td></tr>';
  });
  const tot=tb-tf;
  rows.push('<tr class="tr-tot"><td colspan="3">TOTAL</td><td class="tn"></td><td class="tn">'+fmt(tb)+'</td><td class="tn"></td><td class="tn"></td><td class="tn">'+fmt(tf)+'</td><td class="tn '+(tot>=0?'tp':'tng')+'">'+fmtS(tot)+'</td><td class="tn"></td><td class="tn"></td></tr>');
  document.getElementById('tb-s').innerHTML=rows.join('');
  document.getElementById('s-br').textContent=fmt(tb)+' €';
  document.getElementById('s-fdc').textContent=fmt(tf)+' €';
  document.getElementById('s-ec').textContent=fmtS(tot);
  showVue('vue-synth');
}

function retourFiche(){if(stId)ouvrirST(stId);else goChantiers();}

// ── EXPORT ─────────────────────────────────────────────────
function exportXlsx(){
  const c=ch();if(!c)return;
  const wb=XLSX.utils.book_new();
  let rows=[['SUIVI FINANCIER DES SOUS-TRAITANTS — FLORIOT'],['Chantier :',c.nom,'N° :',c.num,'Gestion :',c.gestion_date||c.date],[],
    ['LOT','ENTREPRISE','DGD','BUDGET P0','BUDGET RECALE','TOTAL MARCHE','RAD','TOTAL FDC','ECART','FDC M-1','ECART M-1']];
  let tb=0,tf=0;
  currentFiches.forEach(f=>{
    const br=getBR(f),fdc=getFDC(f);
    const bp0=(f.budget||[]).reduce((s,r)=>s+n(r.bp0),0);
    const tm=(f.depenses||[]).reduce((s,r)=>s+n(r.marche)+n(r.av),0);
    const rad=(f.depenses||[]).reduce((s,r)=>s+n(r.rad),0);
    tb+=br;tf+=fdc;
    rows.push([f.lot,f.nom,f.dgd,bp0,br,tm,rad,fdc,br-fdc,n(f.fdc_m1),fdc-n(f.fdc_m1)]);
  });
  rows.push(['','','TOTAL','',tb,'','',tf,tb-tf,'','']);
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(rows),'SYNTHESE');
  currentFiches.forEach(f=>{
    const r=[];
    r.push(['FICHE SOUS-TRAITANT'],['Chantier :',c.nom],['ST :',f.nom,'Lot :',f.lot,'DGD :',f.dgd],[]);
    r.push(['BUDGET'],['DESIGNATION','BUDGET P0','TRAVAUX SUP','TRANSFERT','BUDGET RECALE']);
    (f.budget||[]).forEach(b=>r.push([b.desig,n(b.bp0),n(b.sup),n(b.transf),n(b.bp0)+n(b.sup)+n(b.transf)]));
    r.push(['TOTAL',(f.budget||[]).reduce((s,b)=>s+n(b.bp0),0),(f.budget||[]).reduce((s,b)=>s+n(b.sup),0),(f.budget||[]).reduce((s,b)=>s+n(b.transf),0),getBR(f)]);
    r.push([],['DEPENSES'],['QUI','DESIGNATION','PM','MARCHE','AVENANT','N°AV','TOTAL MARCHE','RAD','TOTAL FDC']);
    (f.depenses||[]).forEach(d=>r.push([d.qui,d.desig,n(d.pm),n(d.marche),n(d.av),d.nav,n(d.marche)+n(d.av),n(d.rad),n(d.marche)+n(d.av)+n(d.rad)]));
    r.push([],['ECART'],['Budget recalé',getBR(f)],['Dépenses FDC',getFDC(f)],['Ecart',getBR(f)-getFDC(f)],[],['FDC M-1',n(f.fdc_m1)],['Dépenses FDC',getFDC(f)],['Ecart M-1',getFDC(f)-n(f.fdc_m1)]);
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(r),f.nom.replace(/[/\?*[\]:]/g,'-').substring(0,31));
  });
  XLSX.writeFile(wb,(c.num?c.num+'_':'')+c.nom.replace(/[^a-zA-Z0-9]/g,'_').substring(0,20)+'_SuiviST.xlsx');
}

loadChantiers();
</script>
</body>
</html>
